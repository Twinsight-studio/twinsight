{
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 120,
  "semi": false,
  "singleQuote": true,
  "arrowParens": "always",
  "trailingComma": "all",
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "bracketSameLine": false,
  "insertPragma": false,
  "ignorePath": ".prettierignore",
  "endOfLine": "lf"
}
