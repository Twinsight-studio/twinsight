ENV=local

# PostgreSQL (docker-compose). Used by the app's async engine and by Alembic.
# If you overrode POSTGRES_PORT in the root .env, match the host port here
# when running host-side tools like `make migrate`.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

REDIS_URL=redis://localhost:6379/0

# Fugle market-data API key — backend-only, never expose to the frontend.
FUGLE_API_KEY=

JWT_SECRET=change-me-in-production
