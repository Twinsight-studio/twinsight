ENV=local

# Local dev (docker-compose): plain Postgres, no pooler.
# Production: Supavisor transaction-mode pooler, port 6543.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

# Local dev: same as DATABASE_URL. Production: Supavisor session-mode
# pooler, port 5432 (used by Alembic only — see docs/infra/gcp-setup.md).
DATABASE_MIGRATION_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

REDIS_URL=redis://localhost:6379/0

# Fugle market-data API key — backend-only, never expose to the frontend.
FUGLE_API_KEY=

JWT_SECRET=change-me-in-production
