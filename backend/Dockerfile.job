# twinsight-job — post-market batch. Extra pandas/numpy/pandas-ta/yfinance
# stack via the `job` optional-dependencies group, kept out of the API image
# so the API stays small.
FROM python:3.12-slim

RUN pip install --no-cache-dir uv

WORKDIR /app

COPY pyproject.toml uv.lock* ./
RUN uv sync --no-dev --extra job --no-install-project

COPY app ./app
RUN uv sync --no-dev --extra job

ENV PATH="/app/.venv/bin:${PATH}"

CMD ["python", "-m", "app.jobs.run_batch"]
