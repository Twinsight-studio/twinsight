# docker-compose host-side ports. Defaults match the standard local ports.
# If you already run Postgres/Redis natively (port conflict on `make dev`),
# copy this to `.env` and pick non-colliding ports. The containers still talk
# to each other on the standard internal ports — only the host mapping moves.
#
# NOTE: if you change POSTGRES_PORT and run host-side tools that hit the DB
# directly (e.g. `make migrate` / alembic outside docker), update the host
# port in backend/.env's DATABASE_URL to match.
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8080
FRONTEND_PORT=3000
